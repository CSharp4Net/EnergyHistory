<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CS4N.EnergyHistory.MobileApp.ViewModels"
             x:Class="CS4N.EnergyHistory.MobileApp.Views.SolarStationDetailPage"
             x:DataType="vm:SolarStationViewModel">

  <ContentPage.Content>
    <Grid RowDefinitions="Auto,*">

      <!-- Kopfzeile -->
      <Grid Grid.Row="0"
            BackgroundColor="{AppThemeBinding Light=#1B5E20, Dark=#0A2E10}"
            Padding="8,10">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Button Grid.Column="0"
                Text="‹"
                FontSize="24"
                TextColor="White"
                BackgroundColor="Transparent"
                Clicked="OnBackClicked"
                WidthRequest="44"/>

        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
          <Label Text="{Binding Definition.Name, FallbackValue='Solar-Station'}"
                 TextColor="White"
                 FontSize="18"
                 FontAttributes="Bold"/>
          <Label Text="{Binding Definition.PowerPeak, StringFormat='Peak: {0:N0} W'}"
                 TextColor="#A5D6A7"
                 FontSize="11"
                 IsVisible="{Binding Definition, Converter={StaticResource NotNull}}"/>
        </VerticalStackLayout>
      </Grid>

      <!-- Ladeindikator -->
      <ActivityIndicator Grid.Row="1"
                         IsRunning="{Binding IsBusy}"
                         IsVisible="{Binding IsBusy}"
                         Color="ForestGreen"
                         VerticalOptions="Center"
                         HorizontalOptions="Center"/>

      <!-- Hauptinhalt mit Tabs -->
      <Grid Grid.Row="1" IsVisible="{Binding IsBusy, Converter={StaticResource InvertBool}}">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Tab-Leiste -->
        <HorizontalStackLayout Grid.Row="0" BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1C1C1E}" Spacing="0">
          <Button x:Name="tabSummary"
                  Text="Zusammenfassung"
                  FontSize="13"
                  BackgroundColor="{AppThemeBinding Light=#1B5E20, Dark=#0A2E10}"
                  TextColor="White"
                  CornerRadius="0"
                  HorizontalOptions="FillAndExpand"
                  Clicked="OnTabSummaryClicked"/>
          <Button x:Name="tabEntry"
                  Text="Erfassung"
                  FontSize="13"
                  BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#2C2C2E}"
                  TextColor="{AppThemeBinding Light=#444, Dark=#CCC}"
                  CornerRadius="0"
                  HorizontalOptions="FillAndExpand"
                  Clicked="OnTabEntryClicked"/>
        </HorizontalStackLayout>

        <!-- Tab 1: Zusammenfassung (analog zu Summary-Tab in SolarStationData.view.xml) -->
        <ScrollView Grid.Row="1" x:Name="panelSummary">
          <VerticalStackLayout Padding="16" Spacing="12">

            <!-- Gesamtertrag -->
            <Frame Padding="16" CornerRadius="12" HasShadow="False"
                   BackgroundColor="{AppThemeBinding Light=#E8F5E9, Dark=#1B3A2A}">
              <Grid ColumnDefinitions="*,Auto">
                <VerticalStackLayout Grid.Column="0">
                  <Label Text="Gesamtertrag" FontSize="12" TextColor="Gray"/>
                  <Label Text="{Binding GeneratedAmountDisplay}"
                         FontSize="24" FontAttributes="Bold" TextColor="ForestGreen"/>
                  <Label Text="{Binding AmountPerDayDisplay}" FontSize="12" TextColor="Gray"/>
                </VerticalStackLayout>
                <Label Grid.Column="1" Text="☀️" FontSize="36" VerticalOptions="Center"/>
              </Grid>
            </Frame>

            <!-- Ertragswert & Einspeisung -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
              <Frame Grid.Column="0" Padding="12" CornerRadius="10" HasShadow="False"
                     BackgroundColor="{AppThemeBinding Light=#FFF8E1, Dark=#2D2000}"
                     IsVisible="{Binding GeneratedValueDisplay, Converter={StaticResource StringNotEmpty}}">
                <VerticalStackLayout>
                  <Label Text="Ertragswert" FontSize="11" TextColor="Gray"/>
                  <Label Text="{Binding GeneratedValueDisplay}" FontSize="13" FontAttributes="Bold" TextColor="DarkOrange"/>
                </VerticalStackLayout>
              </Frame>

              <Frame Grid.Column="1" Padding="12" CornerRadius="10" HasShadow="False"
                     BackgroundColor="{AppThemeBinding Light=#E3F2FD, Dark=#1A2D3E}"
                     IsVisible="{Binding FedInValueDisplay, Converter={StaticResource StringNotEmpty}}">
                <VerticalStackLayout>
                  <Label Text="Einspeisevergütung" FontSize="11" TextColor="Gray"/>
                  <Label Text="{Binding FedInValueDisplay}" FontSize="13" FontAttributes="Bold" TextColor="SteelBlue"/>
                </VerticalStackLayout>
              </Frame>
            </Grid>

            <!-- Stammdaten -->
            <Frame Padding="16" CornerRadius="12" HasShadow="False"
                   BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1C1E}">
              <VerticalStackLayout Spacing="8">
                <Label Text="Stammdaten" FontSize="13" FontAttributes="Bold" TextColor="Gray"/>
                <Label Text="{Binding InstalledAtDisplay}" FontSize="14"/>
                <Label Text="{Binding AgeInDaysDisplay}" FontSize="14"/>
                <Label Text="{Binding Definition.CommonComments}"
                       FontSize="13"
                       TextColor="Gray"
                       IsVisible="{Binding Definition.CommonComments, Converter={StaticResource StringNotEmpty}}"/>
              </VerticalStackLayout>
            </Frame>

          </VerticalStackLayout>
        </ScrollView>

        <!-- Tab 2: Jahreserfassung (analog zu SolarStationDataEdit.view.xml) -->
        <CollectionView Grid.Row="1"
                        x:Name="panelEntry"
                        IsVisible="False"
                        ItemsSource="{Binding Years}">
          <CollectionView.Header>
            <VerticalStackLayout Padding="16,12,16,4">
              <Button Text="+ Neues Jahr erfassen"
                      BackgroundColor="ForestGreen"
                      TextColor="White"
                      CornerRadius="8"
                      Clicked="OnAddYearClicked"/>
            </VerticalStackLayout>
          </CollectionView.Header>

          <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="vm:YearRowModel">
              <Frame Margin="12,4" Padding="0" CornerRadius="10" HasShadow="False"
                     BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#2C2C2E}">
                <Expander x:Name="yearExpander">
                  <Expander.Header>
                    <Grid Padding="14,12" ColumnDefinitions="Auto,*,Auto">
                      <Label Grid.Column="0"
                             Text="{Binding Year}"
                             FontSize="16"
                             FontAttributes="Bold"
                             VerticalOptions="Center"/>
                      <Label Grid.Column="1"
                             Text="{Binding GeneratedAmount, StringFormat='{0:N1} kWh'}"
                             FontSize="14"
                             TextColor="ForestGreen"
                             HorizontalOptions="End"
                             VerticalOptions="Center"
                             Margin="0,0,8,0"/>
                      <Label Grid.Column="2" Text="›" FontSize="18" TextColor="Gray" VerticalOptions="Center"/>
                    </Grid>
                  </Expander.Header>

                  <!-- Expandierter Bereich: Monatstabelle -->
                  <VerticalStackLayout Padding="12,0,12,12" Spacing="6" BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#111}">
                    <Label Text="Monatswerte" FontSize="12" TextColor="Gray" Margin="0,0,0,4"/>

                    <CollectionView ItemsSource="{Binding Months}">
                      <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:MonthRowModel">
                          <Grid ColumnDefinitions="60,*,Auto" Padding="0,4">
                            <Label Grid.Column="0"
                                   Text="{Binding MonthName}"
                                   FontSize="13"
                                   VerticalOptions="Center"/>
                            <Entry Grid.Column="1"
                                   Text="{Binding GeneratedAmount}"
                                   Keyboard="Numeric"
                                   HorizontalTextAlignment="End"
                                   FontSize="13"/>
                            <Label Grid.Column="2"
                                   Text="kWh"
                                   FontSize="12"
                                   TextColor="Gray"
                                   VerticalOptions="Center"
                                   Margin="4,0,0,0"/>
                          </Grid>
                        </DataTemplate>
                      </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Button Text="Speichern"
                            BackgroundColor="ForestGreen"
                            TextColor="White"
                            CornerRadius="6"
                            Margin="0,8,0,0"
                            CommandParameter="{Binding .}"
                            Clicked="OnSaveYearClicked"/>
                  </VerticalStackLayout>
                </Expander>
              </Frame>
            </DataTemplate>
          </CollectionView.ItemTemplate>

          <CollectionView.EmptyView>
            <Label Text="Noch keine Jahresdaten erfasst. Tippe auf '+ Neues Jahr' um zu beginnen."
                   HorizontalOptions="Center"
                   TextColor="Gray"
                   HorizontalTextAlignment="Center"
                   Margin="24,40"/>
          </CollectionView.EmptyView>
        </CollectionView>

      </Grid>
    </Grid>
  </ContentPage.Content>
</ContentPage>
