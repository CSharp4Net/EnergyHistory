<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CS4N.EnergyHistory.MobileApp.ViewModels"
             x:Class="CS4N.EnergyHistory.MobileApp.Views.ElectricMeterDetailPage"
             x:DataType="vm:ElectricMeterViewModel">

  <ContentPage.Content>
    <Grid RowDefinitions="Auto,*">

      <!-- Kopfzeile mit Zurück-Button -->
      <Grid Grid.Row="0"
            BackgroundColor="{AppThemeBinding Light=#1C3A5E, Dark=#0D1F35}"
            Padding="8,10">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Button Grid.Column="0"
                Text="‹"
                FontSize="24"
                TextColor="White"
                BackgroundColor="Transparent"
                Clicked="OnBackClicked"
                WidthRequest="44"/>

        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
          <Label Text="{Binding Definition.Name, FallbackValue='Stromzähler'}"
                 TextColor="White"
                 FontSize="18"
                 FontAttributes="Bold"/>
          <Label Text="{Binding Definition.Number, StringFormat='Nr. {0}'}"
                 TextColor="#A0C4E8"
                 FontSize="11"
                 IsVisible="{Binding Definition.Number, Converter={StaticResource StringNotEmpty}}"/>
        </VerticalStackLayout>
      </Grid>

      <!-- Ladeindikator -->
      <ActivityIndicator Grid.Row="1"
                         IsRunning="{Binding IsBusy}"
                         IsVisible="{Binding IsBusy}"
                         VerticalOptions="Center"
                         HorizontalOptions="Center"/>

      <!-- Tab-ähnliche Struktur mit SwipeView — analog zu IconTabBar in UI5 -->
      <!-- Wir nutzen einen einfachen RadioButton-Selektor, der zwei Bereiche umschaltet -->
      <Grid Grid.Row="1" IsVisible="{Binding IsBusy, Converter={StaticResource InvertBool}}">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Tab-Leiste -->
        <HorizontalStackLayout Grid.Row="0"
                               BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1C1C1E}"
                               Spacing="0">
          <Button x:Name="tabRecording"
                  Text="Erfassung"
                  FontSize="13"
                  BackgroundColor="{AppThemeBinding Light=#1C3A5E, Dark=#0D1F35}"
                  TextColor="White"
                  CornerRadius="0"
                  HorizontalOptions="FillAndExpand"
                  Clicked="OnTabRecordingClicked"/>
          <Button x:Name="tabHistory"
                  Text="Historie"
                  FontSize="13"
                  BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#2C2C2E}"
                  TextColor="{AppThemeBinding Light=#444, Dark=#CCC}"
                  CornerRadius="0"
                  HorizontalOptions="FillAndExpand"
                  Clicked="OnTabHistoryClicked"/>
        </HorizontalStackLayout>

        <!-- Tab 1: Erfassung (Neueingabe + aktuelle KPIs) -->
        <ScrollView Grid.Row="1" x:Name="panelRecording">
          <VerticalStackLayout Padding="16" Spacing="0">

            <!-- KPI-Karten: aktuelle Messwerte im Überblick -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10" Margin="0,0,0,20">
              <Frame Grid.Row="0" Grid.Column="0" Padding="12" CornerRadius="10" HasShadow="False"
                     BackgroundColor="{AppThemeBinding Light=#E8F5E9, Dark=#1B3A2A}">
                <VerticalStackLayout>
                  <Label Text="Letzter Stand" FontSize="11" TextColor="Gray"/>
                  <Label Text="{Binding LastRecordValueDisplay}" FontSize="15" FontAttributes="Bold" TextColor="ForestGreen"/>
                  <Label Text="{Binding LastRecordDateDisplay}" FontSize="11" TextColor="Gray"/>
                </VerticalStackLayout>
              </Frame>

              <Frame Grid.Row="0" Grid.Column="1" Padding="12" CornerRadius="10" HasShadow="False"
                     BackgroundColor="{AppThemeBinding Light=#E3F2FD, Dark=#1A2D3E}">
                <VerticalStackLayout>
                  <Label Text="Ø/Tag" FontSize="11" TextColor="Gray"/>
                  <Label Text="{Binding AverageAmountDisplay}" FontSize="15" FontAttributes="Bold" TextColor="SteelBlue"/>
                  <Label Text="{Binding AverageValueDisplay}" FontSize="11" TextColor="Gray"/>
                </VerticalStackLayout>
              </Frame>

              <Frame Grid.Row="1" Grid.Column="0" Padding="12" CornerRadius="10" HasShadow="False"
                     BackgroundColor="{AppThemeBinding Light=#FFF8E1, Dark=#2D2000}">
                <VerticalStackLayout>
                  <Label Text="kWh-Preis" FontSize="11" TextColor="Gray"/>
                  <Label Text="{Binding Definition.KilowattHourPrice, StringFormat='{0:N4} €'}"
                         FontSize="15" FontAttributes="Bold" TextColor="DarkOrange"/>
                </VerticalStackLayout>
              </Frame>

              <Frame Grid.Row="1" Grid.Column="1" Padding="12" CornerRadius="10" HasShadow="False"
                     BackgroundColor="{AppThemeBinding Light=#F3E5F5, Dark=#261633}">
                <VerticalStackLayout>
                  <Label Text="Zähleinheit" FontSize="11" TextColor="Gray"/>
                  <Label Text="{Binding Definition.UnitCode}" FontSize="15" FontAttributes="Bold" TextColor="Purple"/>
                </VerticalStackLayout>
              </Frame>
            </Grid>

            <!-- Eingabeformular: Neue Ablesung erfassen -->
            <Label Text="Neue Ablesung erfassen"
                   FontSize="14"
                   FontAttributes="Bold"
                   Margin="0,0,0,10"/>

            <Label Text="Ablesedatum" FontSize="12" TextColor="Gray"/>
            <DatePicker x:Name="datePickerInput"
                        Format="dd.MM.yyyy"
                        Margin="0,0,0,4"/>
            <Label Text="{Binding DateError}" TextColor="Red" FontSize="12" IsVisible="{Binding DateError, Converter={StaticResource StringNotEmpty}}"/>

            <Label Text="Zählerstand" FontSize="12" TextColor="Gray" Margin="0,8,0,0"/>
            <Grid ColumnDefinitions="*,Auto">
              <Entry Grid.Column="0"
                     x:Name="readingValueEntry"
                     Placeholder="0"
                     Keyboard="Numeric"
                     HorizontalTextAlignment="End"/>
              <Label Grid.Column="1"
                     Text="{Binding Definition.CapacityUnit}"
                     VerticalOptions="Center"
                     Margin="8,0,0,0"
                     TextColor="Gray"/>
            </Grid>
            <Label Text="{Binding ValueError}" TextColor="Red" FontSize="12" IsVisible="{Binding ValueError, Converter={StaticResource StringNotEmpty}}"/>

            <Label Text="kWh-Preis" FontSize="12" TextColor="Gray" Margin="0,8,0,0"/>
            <Grid ColumnDefinitions="*,Auto">
              <Entry Grid.Column="0"
                     x:Name="priceEntry"
                     Keyboard="Numeric"
                     HorizontalTextAlignment="End"/>
              <Label Grid.Column="1"
                     Text="{Binding Definition.CurrencyUnit}"
                     VerticalOptions="Center"
                     Margin="8,0,0,0"
                     TextColor="Gray"/>
            </Grid>

            <Button Text="✓  Ablesung speichern"
                    BackgroundColor="ForestGreen"
                    TextColor="White"
                    CornerRadius="8"
                    Margin="0,16,0,0"
                    Clicked="OnSaveClicked"/>

          </VerticalStackLayout>
        </ScrollView>

        <!-- Tab 2: Historientabelle -->
        <CollectionView Grid.Row="1"
                        x:Name="panelHistory"
                        IsVisible="False"
                        ItemsSource="{Binding Records}">
          <CollectionView.Header>
            <!-- Tabellenheader -->
            <Grid Padding="12,8"
                  ColumnDefinitions="*,Auto,Auto,Auto,Auto"
                  BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2C2C2E}">
              <Label Grid.Column="0" Text="Datum" FontSize="11" FontAttributes="Bold" TextColor="Gray"/>
              <Label Grid.Column="1" Text="Stand" FontSize="11" FontAttributes="Bold" TextColor="Gray" HorizontalOptions="End" Margin="0,0,8,0"/>
              <Label Grid.Column="2" Text="Diff." FontSize="11" FontAttributes="Bold" TextColor="Gray" HorizontalOptions="End" Margin="0,0,8,0"/>
              <Label Grid.Column="3" Text="Tage" FontSize="11" FontAttributes="Bold" TextColor="Gray" HorizontalOptions="End" Margin="0,0,8,0"/>
              <Label Grid.Column="4" Text="" FontSize="11" HorizontalOptions="End"/>
            </Grid>
          </CollectionView.Header>

          <CollectionView.ItemTemplate>
            <DataTemplate>
              <SwipeView>
                <!-- Wisch nach links = Löschen (analog zu Delete-Button in UI5) -->
                <SwipeView.RightItems>
                  <SwipeItems>
                    <SwipeItem Text="Löschen"
                               BackgroundColor="Red"
                               Invoked="OnDeleteRecordInvoked"/>
                  </SwipeItems>
                </SwipeView.RightItems>

                <Grid Padding="12,10"
                      ColumnDefinitions="*,Auto,Auto,Auto,Auto"
                      BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1C1E}">
                  <Label Grid.Column="0"
                         Text="{Binding ReadingDate, StringFormat='{0:dd.MM.yyyy}'}"
                         FontSize="13"
                         VerticalOptions="Center"/>
                  <Label Grid.Column="1"
                         Text="{Binding ReadingValue, StringFormat='{0:N1}'}"
                         FontSize="13"
                         HorizontalOptions="End"
                         Margin="0,0,8,0"/>
                  <Label Grid.Column="2"
                         Text="{Binding DifferenceValue, StringFormat='+{0:N1}'}"
                         FontSize="13"
                         TextColor="SteelBlue"
                         HorizontalOptions="End"
                         Margin="0,0,8,0"/>
                  <Label Grid.Column="3"
                         Text="{Binding DifferenceDays}"
                         FontSize="13"
                         TextColor="Gray"
                         HorizontalOptions="End"
                         Margin="0,0,8,0"/>
                </Grid>
              </SwipeView>
            </DataTemplate>
          </CollectionView.ItemTemplate>

          <CollectionView.EmptyView>
            <Label Text="Noch keine Ablesungen vorhanden."
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   TextColor="Gray"
                   Margin="0,40"/>
          </CollectionView.EmptyView>
        </CollectionView>

      </Grid>
    </Grid>
  </ContentPage.Content>
</ContentPage>
