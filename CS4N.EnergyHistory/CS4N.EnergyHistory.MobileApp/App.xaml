<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:CS4N.EnergyHistory.MobileApp.Converters"
             x:Class="CS4N.EnergyHistory.MobileApp.App">

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
        <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
      </ResourceDictionary.MergedDictionaries>

      <!--
        Globale Converter-Instanzen — einmal deklariert, überall per StaticResource nutzbar.
        Das Konzept entspricht dem Formatter-Muster in SAP UI5 (formatter: '.formatDate'),
        nur dass MAUI die Konvertierung deklarativ im XAML bindet statt imperativ im Controller.
      -->
      <converters:InvertBoolConverter x:Key="InvertBool"/>
      <converters:StringNotEmptyConverter x:Key="StringNotEmpty"/>
      <converters:NotNullConverter x:Key="NotNull"/>

    </ResourceDictionary>
  </Application.Resources>

</Application>
