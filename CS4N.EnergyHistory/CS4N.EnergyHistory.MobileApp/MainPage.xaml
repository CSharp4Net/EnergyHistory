<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CS4N.EnergyHistory.MobileApp.ViewModels"
             x:Class="CS4N.EnergyHistory.MobileApp.MainPage"
             x:DataType="vm:MainViewModel">

  <ContentPage.Content>
    <Grid RowDefinitions="Auto,*,Auto">

      <!-- Kopfzeile analog zu SAP UI5 Bar/customHeader -->
      <Grid Grid.Row="0" BackgroundColor="{AppThemeBinding Light=#1C3A5E, Dark=#0D1F35}"
            Padding="16,12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
          <Label Text="⚡ EnergyHistory"
                 TextColor="White"
                 FontSize="22"
                 FontAttributes="Bold"/>
          <Label Text="Deine Energieübersicht"
                 TextColor="#A0C4E8"
                 FontSize="12"/>
        </VerticalStackLayout>

        <ImageButton Grid.Column="1"
                     Source="settings.png"
                     HeightRequest="28"
                     WidthRequest="28"
                     BackgroundColor="Transparent"
                     Clicked="OnSettingsClicked"
                     ToolTipProperties.Text="Einstellungen"/>
      </Grid>

      <!-- Fehlermeldung (sichtbar bei Ladefehler) -->
      <Frame Grid.Row="1"
             IsVisible="{Binding HasError}"
             BackgroundColor="#FDECEA"
             BorderColor="#E53935"
             Margin="12"
             Padding="12"
             VerticalOptions="Start">
        <Label Text="{Binding ErrorMessage}"
               TextColor="#B71C1C"
               FontSize="14"/>
      </Frame>

      <!-- Ladeindikator -->
      <ActivityIndicator Grid.Row="1"
                         IsRunning="{Binding IsBusy}"
                         IsVisible="{Binding IsBusy}"
                         Color="{AppThemeBinding Light=#1C3A5E, Dark=#A0C4E8}"
                         HorizontalOptions="Center"
                         VerticalOptions="Center"/>

      <!-- Hauptinhalt: Gruppierte Kachelliste -->
      <CollectionView Grid.Row="1"
                      ItemsSource="{Binding Groups}"
                      IsGrouped="True"
                      IsVisible="{Binding IsBusy, Converter={StaticResource InvertBool}}"
                      SelectionMode="Single"
                      SelectionChanged="OnTileSelected">

        <!-- Gruppenüberschrift (z.B. "PV-Stationen", "Stromzähler") -->
        <CollectionView.GroupHeaderTemplate>
          <DataTemplate>
            <Label Text="{Binding Key}"
                   FontSize="13"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#1C3A5E, Dark=#A0C4E8}"
                   Padding="16,12,16,4"
                   TextTransform="Uppercase"
                   CharacterSpacing="1.2"/>
          </DataTemplate>
        </CollectionView.GroupHeaderTemplate>

        <!-- Kachelvorlage — entspricht GenericTile in UI5 -->
        <CollectionView.ItemTemplate>
          <DataTemplate x:DataType="vm:TileModel">
            <Border Margin="12,4"
                    Padding="0"
                    StrokeShape="RoundRectangle 12"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#2C2C2E}">
              <Border.Shadow>
                <Shadow Brush="{AppThemeBinding Light=Gray, Dark=Black}"
                        Offset="0,2"
                        Radius="4"
                        Opacity="0.15"/>
              </Border.Shadow>

              <Grid ColumnDefinitions="Auto,*,Auto"
                    Padding="14,12"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1C1E}">

                <!-- Kategorie-Indikator-Balken links -->
                <BoxView Grid.Column="0"
                         WidthRequest="4"
                         HeightRequest="40"
                         CornerRadius="2"
                         Color="{Binding KpiColor}"
                         Margin="0,0,12,0"
                         VerticalOptions="Center"/>

                <!-- Name + Footer (letzte Ablesung / Ertrag) -->
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                  <Label Text="{Binding Name}"
                         FontSize="15"
                         FontAttributes="Bold"/>
                  <Label Text="{Binding FooterText}"
                         FontSize="12"
                         TextColor="Gray"
                         IsVisible="{Binding FooterText, Converter={StaticResource StringNotEmpty}}"/>
                </VerticalStackLayout>

                <!-- KPI-Wert rechts (letzter Zählerstand / Gesamtertrag) -->
                <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" HorizontalOptions="End">
                  <Label Text="{Binding KpiText}"
                         FontSize="16"
                         FontAttributes="Bold"
                         TextColor="{Binding KpiColor}"
                         HorizontalOptions="End"/>
                  <Label Text="›"
                         FontSize="18"
                         TextColor="Gray"
                         HorizontalOptions="End"/>
                </VerticalStackLayout>
              </Grid>
            </Border>
          </DataTemplate>
        </CollectionView.ItemTemplate>

        <!-- Platzhalter wenn keine Daten -->
        <CollectionView.EmptyView>
          <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="12" Padding="24">
            <Label Text="⚡" FontSize="48" HorizontalOptions="Center"/>
            <Label Text="Noch keine Geräte erfasst"
                   FontSize="16"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"/>
            <Label Text="Lege in den Einstellungen zunächst fest, wo deine Daten gespeichert sind, und erfasse dann über die WebApp deine ersten Zähler."
                   FontSize="13"
                   TextColor="Gray"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"/>
          </VerticalStackLayout>
        </CollectionView.EmptyView>
      </CollectionView>

      <!-- Fußzeile mit letztem Ladesatus -->
      <Label Grid.Row="2"
             x:Name="lastRefreshLabel"
             HorizontalOptions="Center"
             FontSize="10"
             TextColor="Gray"
             Padding="0,4"/>

    </Grid>
  </ContentPage.Content>
</ContentPage>
